# ==============================================================================
# AQI Monitoring System - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aqi_db

# ──────────────────────────────────────────────────────────────────────────────
# MQTT BROKER (for local development)
# ──────────────────────────────────────────────────────────────────────────────
# For LOCAL development, use your local Mosquitto or public test broker
# MQTT_BROKER=mqtt://localhost:1883

# For PRODUCTION on Vercel, use a cloud MQTT service:
# - HiveMQ Cloud: mqtt://broker.hivemq.com:1883
# - AWS IoT Core: (requires custom certificate)
# - DigitalOcean: mqtt://broker-region.digitalocean.com:1883
# - Self-hosted on VPS: mqtt://your-domain.com:1883

MQTT_BROKER=mqtt://localhost:1883
MQTT_USER=
MQTT_PASS=

# ──────────────────────────────────────────────────────────────────────────────
# AQI ALERT THRESHOLD
# ──────────────────────────────────────────────────────────────────────────────
# Alert when AQI exceeds this value
AQI_ALERT_THRESHOLD=100

# ──────────────────────────────────────────────────────────────────────────────
# BACKEND SERVER
# ──────────────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND API (optional, set in vite.config.ts or as environment variable)
# ──────────────────────────────────────────────────────────────────────────────
# VITE_API_BASE_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────────────────────────
# VERCEL (automatically set, no need to configure)
# ──────────────────────────────────────────────────────────────────────────────
# VERCEL=1 (automatically set to '1' when running on Vercel)
